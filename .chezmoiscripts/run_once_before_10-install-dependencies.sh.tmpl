#!/bin/bash

# This script installs Ansible and runs the playbook to provision the machine
# It runs BEFORE dotfiles are applied

set -e

{{ if eq .chezmoi.os "darwin" -}}
# =============================================================================
# macOS Setup
# =============================================================================

echo "Setting up macOS environment..."

# Ensure Homebrew is available
eval "$(/opt/homebrew/bin/brew shellenv)" 2>/dev/null || eval "$(/usr/local/bin/brew shellenv)" 2>/dev/null || true

# Install Ansible
if ! command -v ansible-playbook &> /dev/null; then
    echo "Installing Ansible..."
    brew install ansible
fi

# Install Ansible collections
echo "Installing Ansible collections..."
ansible-galaxy collection install community.general --force

# Run Ansible playbook
echo "Running Ansible playbook..."
pushd "{{ .chezmoi.sourceDir }}/dot_config/ansible_playbooks"
ansible-playbook -v -i inventory.ini playbook.yml --become --ask-become-pass -e "ansible_user_name={{ .chezmoi.username }}"
popd

{{ else if eq .chezmoi.os "linux" -}}
# =============================================================================
# Linux Setup
# =============================================================================

echo "Setting up Linux environment..."

# Detect distribution
if [ -f /etc/os-release ]; then
    . /etc/os-release
    DISTRO_ID=$ID
else
    echo "Could not detect Linux distribution"
    exit 1
fi

# Install dependencies based on distribution
case $DISTRO_ID in
    ubuntu|debian)
        echo "Debian/Ubuntu detected, installing dependencies..."
        sudo apt-get update
        sudo apt-get install -y ansible git gpg
        ;;
    opensuse*)
        echo "openSUSE detected, installing dependencies..."
        sudo zypper install -y ansible git gpg
        ;;
    arch)
        echo "Arch Linux detected, installing dependencies..."
        sudo pacman -Syu --noconfirm ansible git gnupg
        ;;
    *)
        echo "Unsupported Linux distribution: $DISTRO_ID"
        exit 1
        ;;
esac

# Install Ansible collections
echo "Installing Ansible collections..."
ansible-galaxy collection install community.general --force

# Run Ansible playbook
echo "Running Ansible playbook..."
pushd "{{ .chezmoi.sourceDir }}/dot_config/ansible_playbooks"
ansible-playbook -v -i inventory.ini playbook.yml --become --ask-become-pass -e "ansible_user_name={{ .chezmoi.username }}"
popd

{{ else -}}
# =============================================================================
# Unsupported OS
# =============================================================================

echo "Warning: Unsupported operating system '{{ .chezmoi.os }}'"
echo "Skipping automated provisioning."

{{ end -}}
